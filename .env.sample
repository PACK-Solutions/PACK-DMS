# Database configuration
DATABASE_URL=postgres://postgres:password@localhost:5432/packdms

# Security / Auth
JWT_ISSUER=https://your-issuer.example.com
JWKS_URL=https://your-issuer.example.com/.well-known/jwks.json

# S3-compatible storage (RustFS / MinIO)
# If S3_ENDPOINT_URL is set, S3 storage is used; otherwise falls back to STORAGE_PATH
S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET=packdms
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# File-system fallback (used when S3_ENDPOINT_URL is not set)
STORAGE_PATH=./data

# Server
BIND=0.0.0.0:8080
RUST_LOG=info,tower_http=info
